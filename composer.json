{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.4",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-pdo": "*",
        "cviebrock/eloquent-sluggable": "^8.0",
        "fideloper/proxy": "^4.2",
        "fruitcake/laravel-cors": "^2.0",
        "galahad/laravel-addressing": "^2.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "jpkleemans/attribute-events": "^1.0",
        "laravel/framework": "^8.0",
        "laravel/legacy-factories": "^1.0",
        "laravel/sanctum": "^2.4",
        "laravel/tinker": "^2.0",
        "laravel/ui": "^3.0",
        "mll-lab/graphql-php-scalars": "^3.1",
        "nuwave/lighthouse": "dev-master",
        "owen-it/laravel-auditing": "^10.0",
        "sentry/sentry-laravel": "^1.8",
        "spatie/laravel-multitenancy": "^1.0",
        "spatie/laravel-permission": "^3.13"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^2.7",
        "facade/ignition": "^2.3.6",
        "fzaninotto/faker": "^1.9.1",
        "haydenpierce/class-finder": "^0.4.2",
        "laravel/homestead": "^11.0",
        "mockery/mockery": "^1.3.1",
        "nunomaduro/collision": "^5",
        "phpunit/phpunit": "^9"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeders",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
